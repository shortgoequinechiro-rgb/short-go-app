# ── Supabase Configuration ──────────────────────────────────────────────────
# Your Supabase project URL (from project settings)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase public/anonymous key (safe to expose in client code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY_HERE

# Supabase service role key (keep this secret — server-only)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── Email Configuration (Resend) ────────────────────────────────────────────
# Resend API key for transactional emails
RESEND_API_KEY=re_YOUR_KEY_HERE

# From email address (must be verified in Resend)
FROM_EMAIL="Your App <noreply@yourdomain.com>"

# ── AI/LLM Configuration ────────────────────────────────────────────────────
# OpenAI API key for AI features
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# ── SMS Configuration (Twilio) ──────────────────────────────────────────────
# Twilio Account SID
TWILIO_ACCOUNT_SID=AC_YOUR_ACCOUNT_SID_HERE

# Twilio Auth Token
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE

# Twilio Phone Number (with country code, e.g., +1)
TWILIO_PHONE_NUMBER=+1_YOUR_PHONE_NUMBER

# ── Stripe Billing ──────────────────────────────────────────────────────────
# Stripe public/publishable key (safe to expose in client code)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Stripe secret key (keep this secret — server-only)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Stripe webhook secret (for handling Stripe events)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe product price IDs for subscription tiers
STRIPE_PRICE_MONTHLY=price_YOUR_MONTHLY_PRICE_ID
STRIPE_PRICE_ANNUAL=price_YOUR_ANNUAL_PRICE_ID

# Public Stripe price IDs (for client-side references)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_YOUR_MONTHLY_PRICE_ID
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=price_YOUR_ANNUAL_PRICE_ID

# ── Application Configuration ───────────────────────────────────────────────
# Your deployed app URL (no trailing slash). Used for Stripe redirect URLs.
NEXT_PUBLIC_APP_URL=https://your-app.com

# ── E2E Testing (Development Only) ──────────────────────────────────────────
# Email address for automated testing
E2E_USER_EMAIL=test@example.com

# Password for automated testing
E2E_USER_PASSWORD=YOUR_TEST_PASSWORD_HERE
